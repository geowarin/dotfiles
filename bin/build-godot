#!/usr/bin/env bash

git tag -d last-build 2>/dev/null; or true
git tag last-build origin/master

set -e

pushd /home/geo/dev/godot/

VERSION=$(python -c 'import importlib
version = importlib.import_module("version")
print("{0}.{1}.{2}".format(version.major, version.minor, version.status))
')
TEMPLATE_DIR="$HOME/.local/share/godot/export_templates/$VERSION"
LTO=auto

for i in "$@"
do
case $i in
    -m*|--mono*)
    MONO=1
    TEMPLATE_DIR=$HOME/.local/share/godot/export_templates/4.2.dev.mono
    ;;
    -e*|--export-templates*)
    EXPORT_TEMPLATES=1
    ;;
    --lto*)
    LTO=full
    ;;
    --no-lto*)
    LTO=none
    ;;
    --tracy*)
    BUILD_OPTS="$BUILD_OPTS profiler_path=/home/geo/dev/tools/tracy"
    BUILD_OPTS="$BUILD_OPTS profiler=tracy"
    ;;
    # -l=*|--lib=*)
    # DIR="${i#*=}"
    # ;;
    *)
    # unknown option
    ;;
esac
done

# CachyOS flags
CFLAGS="-march=native -O3 -pipe -fno-plt -fexceptions \
        -Wp,-D_FORTIFY_SOURCE=3 -Wformat -Werror=format-security \
        -fstack-clash-protection -fcf-protection"
CXXFLAGS="$CFLAGS -Wp,-D_GLIBCXX_ASSERTIONS"
LDFLAGS="-Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,relro -Wl,-z,now \
         -Wl,-z,pack-relative-relocs"

# https://gitlab.archlinux.org/archlinux/packaging/packages/godot/-/blob/main/PKGBUILD?ref_type=heads

_args=(
#  -j$(nproc --all)
  cflags="$CFLAGS -fPIC -Wl,-z,relro,-z,now -w"
  cxxflags="$CXXFLAGS -fPIC -Wl,-z,relro,-z,now -w"
  linkflags="$LDFLAGS"
#  arch=$_CARCH
  production=yes
  scu_build=yes
#  mold does not seem to work with system libraries
#  linker=mold
  compiledb=yes
# using embedded libs
  builtin_clipper2=yes
  builtin_enet=yes
  builtin_glslang=yes
  builtin_harfbuzz=yes
  builtin_icu4c=yes
  builtin_mbedtls=yes
  builtin_msdfgen=yes
  builtin_recastnavigation=yes
  builtin_rvo2_2d=yes
  builtin_rvo2_3d=yes
  builtin_wslay=yes
  builtin_xatlas=yes
# using system libs
  builtin_brotli=no
  builtin_certs=no
  builtin_embree=no
  builtin_freetype=no
  builtin_graphite=no
  builtin_libogg=no
  builtin_libpng=no
  builtin_libtheora=no
  builtin_libvorbis=no
  builtin_libwebp=no
  builtin_miniupnpc=no
  builtin_openxr=no
  builtin_pcre2=no
  builtin_pcre2_with_jit=no
  builtin_squish=no
  builtin_zlib=no
  builtin_zstd=no
#  colored=yes
#  debug_symbols=yes
#  disable_exceptions=false
#  platform=linuxbsd
#  pulseaudio=yes
#  production=yes
  system_certs_path=/etc/ssl/certs/ca-certificates.crt
#  target=editor
#  use_llvm=no
#  werror=no
)

echo "${_args[@]}"

if [[ $MONO -eq 1 ]];
then
    scons lto=$LTO module_mono_enabled=yes "${_args[@]}"
else
    scons lto=$LTO "${_args[@]}"
fi

if [[ $MONO -eq 1 ]];
then
    ./bin/godot.linuxbsd.editor.x86_64.mono --headless --generate-mono-glue modules/mono/glue
    #dotnet nuget add source ~/dev/LocalNugetSource --name LocalNugetSource
    ./modules/mono/build_scripts/build_assemblies.py --godot-output-dir=./bin \
        --push-nupkgs-local ~/dev/LocalNugetSource
fi

if [[ $EXPORT_TEMPLATES -eq 1 ]];
then
    scons target=template_release scu_build=yes platform=linuxbsd
    mkdir -p "$TEMPLATE_DIR"
    mv bin/godot.linuxbsd.template_release.x86_64 "$TEMPLATE_DIR/linux_release.x86_64"

    scons target=template_release scu_build=yes dlink_enabled=yes platform=web
    mkdir -p "$TEMPLATE_DIR"
    mv bin/godot.web.template_release.wasm32.dlink.zip "$TEMPLATE_DIR/web_dlink_release.zip"

    scons target=template_debug scu_build=yes dlink_enabled=yes platform=web
    mkdir -p "$TEMPLATE_DIR"
    mv bin/godot.web.template_debug.wasm32.dlink.zip "$TEMPLATE_DIR/web_dlink_debug.zip"

    if [[ $MONO -eq 1 ]];
    then
        scons target=template_debug scu_build=yes module_mono_enabled=yes platform=linuxbsd
        mv bin/godot.linuxbsd.template_release.x86_64.mono "$TEMPLATE_DIR/linux_release.x86_64"
    fi
fi


if [[ $MONO -eq 1 ]];
then
    ln -fs "$PWD/bin/godot.linuxbsd.editor.x86_64.mono" "$HOME/bin/godot-master"
else
    ln -fs "$PWD/bin/godot.linuxbsd.editor.x86_64" "$HOME/bin/godot-mono-master"
fi

popd
